rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc(institutionId) {
      return get(/databases/$(database)/documents/institutions/$(institutionId)/users/$(request.auth.uid));
    }

    function isInstitutionMember(institutionId) {
      return isSignedIn() && exists(/databases/$(database)/documents/institutions/$(institutionId)/users/$(request.auth.uid))
        && userDoc(institutionId).data.status == 'active';
    }

    function role(institutionId) {
      return userDoc(institutionId).data.role;
    }

    function isAdmin(institutionId) {
      return isInstitutionMember(institutionId) && role(institutionId) == 'admin';
    }

    function isFaculty(institutionId) {
      return isInstitutionMember(institutionId) && role(institutionId) == 'faculty';
    }

    function isStudent(institutionId) {
      return isInstitutionMember(institutionId) && role(institutionId) == 'student';
    }

    // Institution directory: public read for picker UI (no auth required).
    match /institutions/{institutionId} {
      allow read: if true;
      // Spark-only: allow one-time admin bootstrapping by updating hasAdmin/adminUid.
      allow create: if false;
      allow update: if isSignedIn()
        && resource.data.hasAdmin != true
        && request.resource.data.hasAdmin == true
        && request.resource.data.adminUid == request.auth.uid;
      allow delete: if false;

      // Users / claims mirror (per institution)
      match /users/{uid} {
        allow read: if isAdmin(institutionId) || (isSignedIn() && request.auth.uid == uid);

        // One-time bootstrap: first admin can create their own user doc as admin only if institution hasAdmin is not set.
        allow create: if isSignedIn()
          && request.auth.uid == uid
          && request.resource.data.role == 'admin'
          && request.resource.data.status == 'active'
          && get(/databases/$(database)/documents/institutions/$(institutionId)).data.hasAdmin != true;

        // Admin can create/update users. Users can update their own limited profile.
        allow update: if (isAdmin(institutionId)) ||
          (isSignedIn() && request.auth.uid == uid);
        allow delete: if isAdmin(institutionId);
      }

      // Join requests (user requests access; admin approves by creating /users/{uid})
      match /join_requests/{uid} {
        allow read: if (isAdmin(institutionId)) || (isSignedIn() && request.auth.uid == uid);
        allow create, update: if isSignedIn() && request.auth.uid == uid;
        allow delete: if isAdmin(institutionId) || (isSignedIn() && request.auth.uid == uid);
      }

      // Admin sees everything, faculty reads operational data, students see only student_views.
      match /faculty/{docId} {
        allow read: if isAdmin(institutionId) || isFaculty(institutionId);
        allow write: if isAdmin(institutionId);
      }

      match /students/{docId} {
        allow read: if isAdmin(institutionId) || isFaculty(institutionId);
        allow write: if isAdmin(institutionId);
      }

      match /rooms/{docId} {
        allow read: if isAdmin(institutionId) || isFaculty(institutionId);
        allow write: if isAdmin(institutionId);
      }

      match /sessions/{docId} {
        allow read: if isAdmin(institutionId) || isFaculty(institutionId);
        allow write: if isAdmin(institutionId);
      }

      match /exam_events/{docId} {
        allow read: if isAdmin(institutionId) || isFaculty(institutionId);
        allow write: if isAdmin(institutionId);

        // Any nested subcollections under exam_events are also admin/faculty readable by default.
        match /{subPath=**} {
          allow read: if isAdmin(institutionId) || isFaculty(institutionId);
          allow write: if isAdmin(institutionId);
        }
      }

      match /allocations/{docId} {
        allow read: if isAdmin(institutionId) || isFaculty(institutionId);
        allow write: if isAdmin(institutionId);
      }

      match /leaves/{leaveId} {
        allow read: if isAdmin(institutionId) || isFaculty(institutionId);
        allow create: if isFaculty(institutionId) && request.resource.data.facultyUid == request.auth.uid;
        allow update: if (isAdmin(institutionId)) ||
          (isFaculty(institutionId) && resource.data.facultyUid == request.auth.uid && request.resource.data.facultyUid == request.auth.uid);
        allow delete: if isAdmin(institutionId);
      }

      // Student-safe projections (no neighbor / invigilator leakage)
      match /student_views/{uid} {
        allow read: if isStudent(institutionId) && request.auth.uid == uid;
        allow write: if isAdmin(institutionId);
      }
    }
  }
}
